# Copy to .env and fill in. NEVER commit .env (see .gitignore).
# Free Gemini API key: https://aistudio.google.com/apikey
GEMINI_API_KEY=your-key-here

# Optional: LangSmith tracing/observability — https://smith.langchain.com (free tier).
# Uncomment and set these to see every agent run traced (nodes, LLM calls, latency, cost).
# LANGSMITH_TRACING=true
# LANGSMITH_API_KEY=lsv2_...
# LANGSMITH_PROJECT=research-agent
